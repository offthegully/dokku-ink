{
  "name": "dokku-ink",
  "version": "0.1.1",
  "description": "A terminal dashboard & cheat sheet for Dokku. Read-only visualizer that runs directly on your Dokku host.",
  "type": "module",
  "bin": {
    "dokku-ink": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/offthegully/dokku-ink.git"
  },
  "homepage": "https://github.com/offthegully/dokku-ink#readme",
  "bugs": {
    "url": "https://github.com/offthegully/dokku-ink/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "build:binary": "bun scripts/build.ts",
    "build:binaries": "bun scripts/build-all.ts",
    "dev": "tsx src/index.tsx",
    "demo": "tsx src/index.tsx --demo",
    "dev:bun": "bun src/index.tsx",
    "demo:bun": "bun src/index.tsx --demo",
    "start": "node dist/index.js",
    "start:bun": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "dokku",
    "dashboard",
    "tui",
    "ink",
    "terminal",
    "typescript",
    "paas"
  ],
  "license": "MIT",
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
